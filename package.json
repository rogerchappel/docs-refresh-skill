{
  "name": "docs-refresh-skill",
  "version": "0.1.0",
  "description": "Detect documentation drift against package scripts, CLI bins, examples, and local files.",
  "type": "module",
  "bin": {
    "docs-refresh-skill": "./bin/cli.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "examples",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "SKILL.md"
  ],
  "scripts": {
    "test": "node --test",
    "check": "node --check src/*.js bin/cli.js tests/*.test.js",
    "build": "node scripts/build.js",
    "smoke": "node bin/cli.js --help && node scripts/smoke.js",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "agents",
    "cli",
    "dry-run"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/docs-refresh-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/docs-refresh-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/docs-refresh-skill#readme"
}
